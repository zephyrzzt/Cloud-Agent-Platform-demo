APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=sqlite:///./cloud_agent.db
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_ROOT=./.local/artifacts
WORKSPACE_ROOT=./.local/workspaces

SANDBOX_PROVIDER=docker
SANDBOX_IMAGE=cloud-agent-sandbox:latest
SANDBOX_NETWORK=none
SANDBOX_COMMAND_TIMEOUT_SECONDS=30
SANDBOX_MAX_OUTPUT_BYTES=20000

DEFAULT_MODEL_PROVIDER=mock
DEFAULT_MODEL_NAME=mock-agent

OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=60

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
